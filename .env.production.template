# Production Environment Variables Template
# Copy this file to .env.production and fill in the actual values
# NEVER commit the actual .env.production file to version control

# =============================================================================
# CRITICAL: Generate secure values for production deployment
# =============================================================================

# Rails Secret Key Base (generate with: bundle exec rails secret OR openssl rand -hex 64)
SECRET_KEY_BASE=

# Rails Master Key (found in config/master.key or generate new credentials)
# RAILS_MASTER_KEY=

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_HOST=
DATABASE_NAME=ucnrs_rams_production
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_PORT=3306

# =============================================================================
# Application Configuration
# =============================================================================
HOST=rams.example.com
PROTOCOL=https
PORT=3000

# =============================================================================
# Email/SMTP Configuration
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_DOMAIN=
SMTP_USERNAME=
SMTP_PASSWORD=

# =============================================================================
# AWS Configuration (for S3 file storage)
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
# AWS_BUCKET=ucnrs-rams-production

# =============================================================================
# Puma Web Server Configuration
# =============================================================================
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5
RAILS_MIN_THREADS=5

# =============================================================================
# Rails Environment
# =============================================================================
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true

# =============================================================================
# Optional: Performance and Monitoring
# =============================================================================
# RAILS_LOG_LEVEL=info
# NEW_RELIC_LICENSE_KEY=
# SENTRY_DSN=

# =============================================================================
# Optional: Redis (if used for caching or background jobs)
# =============================================================================
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================
# FORCE_SSL=true

