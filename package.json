{
  "name": "ucnrs-rams",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@babel/core": "7",
    "@babel/plugin-transform-runtime": "7",
    "@babel/plugin-transform-typescript": "^7.15.0",
    "@babel/preset-env": "7",
    "@babel/preset-typescript": "^7.23.2",
    "@babel/runtime": "7",
    "@hotwired/stimulus": "^3.0.1",
    "@hotwired/stimulus-webpack-helpers": "^1.0.1",
    "@hotwired/turbo-rails": "^8.0",
    "@rails/actioncable": "~8.1.0",
    "@rails/actiontext": "~8.1.0",
    "@rails/activestorage": "~8.1.0",
    "@rails/ujs": "~7.1.0",
    "babel-loader": "10",
    "chart.js": "4",
    "chartkick": "^5.0.1",
    "compression-webpack-plugin": "12",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "pnp-webpack-plugin": "1",
    "sass": "^1.99.0",
    "shakapacker": "10",
    "stimulus-autocomplete": "^3.0.0-rc.5",
    "terser-webpack-plugin": "5",
    "trix": "^2.0.2",
    "typescript": "^6.0",
    "webpack": "5",
    "webpack-assets-manifest": "6",
    "webpack-cli": "7.0",
    "webpack-merge": "6"
  },
  "devDependencies": {
    "@types/jest": "^30.0",
    "babel-jest": "^30.0",
    "jest": "^30.0",
    "jest-environment-jsdom": "^30.2.0",
    "webpack-dev-server": "^5.0"
  },
  "babel": {
    "presets": [
      "./node_modules/shakapacker/package/babel/preset.js"
    ],
    "plugins": [
      [
        "@babel/plugin-transform-typescript",
        {
          "allowDeclareFields": true
        }
      ]
    ]
  },
  "browserslist": [
    "defaults"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "testRegex": [
      "./app/javascript/.*_spec\\.[jt]s"
    ],
    "setupFiles": [
      "./app/javascript/setup.js"
    ]
  },
  "scripts": {
    "build:css": "sass ./app/assets/stylesheets/application.sass.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules --load-path=app/assets/stylesheets"
  }
}
