<turbo-stream action="update" target="modal-content">
  <template>
      <div class="modal-content" data-modal-target="dialog openOnLoad">
        <div class="close">
          <%= image_tag "x.svg", height: "16px", width: "16px",
            id: "x-icon",
            data: { action: "click->modal#close" },
            alt: t("alt.icon_x")
          %>
        </div>
        <%= render partial: "dashboard/index_content" %>
      </div>
  </template>
</turbo-stream>
