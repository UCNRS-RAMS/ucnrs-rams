<div id="calendar" class="simple-calendar">
  <div class="calendar-heading">
    <%= link_to(calendar.url_for_previous_view) do %>
      <%= image_tag "arrow-left.svg", alt: t(".alt.left_facing_arrow") %>
    <% end %>
    <%= form_with url: @presenter.calendar_path, method: :get, local: true do |f| %>
      <%=  f.month_field :start_date, value: "#{start_date.strftime('%Y-%m')}", onclick: "showPicker()" , onchange: "this.form.requestSubmit();", class: "calendar-title" %>
    <% end %>
    <%= link_to(calendar.url_for_next_view) do %>
      <%= image_tag "arrow-right.svg", alt: t(".alt.right_facing_arrow") %>
    <% end %>
  </div>

  <table class="table table-striped">
    <thead>
      <tr>
        <% date_range.slice(0, 7).each do |day| %>
          <th><%= t('date.abbr_day_names')[day.wday] %></th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% date_range.each_slice(7) do |week| %>
        <tr>
          <% week.each do |day| %>
            <%= content_tag :td, id: day, class: calendar.td_classes_for(day) do %>
              <% if defined?(Haml) && respond_to?(:block_is_haml?) && block_is_haml?(passed_block) %>
                <% capture_haml(day, sorted_events.fetch(day, []), &passed_block) %>
              <% else %>
                <% passed_block.call day, sorted_events.fetch(day, []) %>
              <% end %>
            <% end %>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
