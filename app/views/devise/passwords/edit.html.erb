<% content_for(:title) { t(".title") } %>
<h1><%= t(".title") %></h1>

<div class="navigation">
  <%= link_to new_user_session_path do %>
    <%= image_tag "arrow-left", height: "24px", width: "24px", alt: "left arrow" %>
    <span><%= t(".go_back") %></span>
  <% end %>
</div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>

  <%= f.hidden_field :reset_password_token %>

  <% if resource.errors[:reset_password_token].present? %>
    <section class="instructions">
      The token used to identify you has expired. Please resend the password reset email and try again.
    </section>
  <% end %>

  <div class="field">
    <%= f.label :password do %>
      <span>
        <%= t(".password") %>
        <% if resource.errors[:password].present? %>
          <em class="errors">(<%= resource.errors[:password].join(", ") %>)</em>
        <% elsif @minimum_password_length %>
          <em>(<%= @minimum_password_length %> characters minimum)</em>
        <% end %>
      </span>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password" %>
    <% end %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation do %>
      <span>
      <%= t(".password_confirmation") %>
        <% if resource.errors[:password_confirmation].present? %>
          <em class="errors"><%= resource.errors[:password_confirmation].join(", ") %></em>
        <% end %>
      </span>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
    <% end %>
  </div>

  <div class="actions">
    <%= f.submit t(".submit") %>
  </div>

  <section class="afterword extra_actions">
    <%= t(".having_trouble") %>
    <%= link_to t(".contact_us"), "mailto:hello@ucnrs.org" %>
  </section>
<% end %>
