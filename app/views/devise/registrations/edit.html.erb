<% content_for(:title) { t(".header.title") } %>

<div class="content">
  <header>
    <div class="h-with-link">
      <h1><%= t(".header.title") %></h1>
      <%= link_to t(".header.sign_out"), destroy_user_session_path, class: "icon icon-sign-out" %>
    </div>
    <p><%= t(".header.description") %></p>
  </header>

  <%= form_with model: @presenter.form_user, url: user_registration_path, data: { turbo: false } do |f| %>
    <%= render partial: "user_fields", locals: { f: f, presenter: @presenter } %>
    <% if @presenter.form_user.terms_accepted_at == nil %>
      <%= render partial: "terms_accepted_at_field", locals: { f: f, presenter: @presenter } %>
    <% end %>
    <div class="section-container blue-bg">
      <section class="actions blue-bg">
        <div class="actions">
          <span><%= image_tag("arrow-left.svg", alt: t("alt.left_facing_arrow")) %> <%= link_to t(".links.go_back"), root_path %></span>
          <%= f.button t(".links.edit_account", icon: image_tag("arrow-right.svg", alt: t("alt.right_facing_arrow"))).html_safe, type: :submit, class: "active" %>
        <div>
      </section>
    </div>
  <% end %>
</div>
