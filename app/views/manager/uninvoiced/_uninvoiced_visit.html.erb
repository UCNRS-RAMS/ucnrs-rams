<tr class="visit <%= visit.status_class %>">
  <td class="date-range"><%= tag.strong visit.requested_date_range %></td>
  <td>
    <%= link_to visit.applicant_name,
      edit_manager_reserve_user_path(current_reserve, visit.user_id),
      data: { "turbo-frame" => "_top" }
    %>
  </td>
  <td>
    <%= t("universal.project.project_types.#{visit.project_type}") %>
    |
    <%= link_to visit.purpose_of_visit,
      manager_reserve_visit_path(current_reserve, visit.id),
      data: { "turbo-frame" => "_top" }
    %>
  </td>
  <td>
    <%= link_to manager_reserve_visit_path(current_reserve, visit.id, selected_tab: "invoices"),
      data: { "turbo-frame" => "_top" } do
    %>
      <%= image_tag "arrow-right-circle.svg", class: "right-arrow", alt: t("alt.right_facing_arrow"), height: "20", width: "20" %>
    <% end %>
  </td>
</tr>
