<% content_for(:title) { t(".title") } %>
<%= render partial: "projects/steps", locals: { presenter: @presenter } %>

<section class="add-funding-form">
  <header class="form-container">
    <h1><%= t(".title") %></h1>
  </header>

  <turbo-frame id="project-details">
    <div id="project-fundings">
      <section class="form-subsection background-1">
        <div class="form-container">
          <header>
            <h2><%= t(".add_funding_title") %></h2>
          </header>
          <%= form_with model: @presenter.form,
            url: manager_reserve_project_fundings_url(current_reserve, @presenter.project),
            namespace: "new" do |form|
          %>
            <turbo-frame id="new-funding-form">
              <%= render partial: "shared/projects/fundings/form_fields", locals: { presenter: @presenter, form: form } %>
            </turbo-frame>
            <div class="form-end">
              <%= form.submit t(".add_funding_submit"), class: "button-clear", data: { disable_with: false } %>
            </div>
          <% end %>
        </div>
      </section>
      <section data-scroll-target="scrollPosition" class="funding-table-section form-subsection form-container" >
        <header>
          <h2><%= t(".project_funding") %></h2>
        </header>
        <%= render partial: "shared/projects/fundings/funding_table", locals: { presenter: @presenter } %>
      </section>
    </div>
  </turbo-frame>
</section>

<section class="controls">
  <%= link_to manager_reserve_project_questions_path(current_reserve, project_id: @presenter.project) do %>
    <%= image_tag "arrow-left-blue.svg", height: "16px", width: "16px", alt: t("alt.left_facing_arrow")  %>
    <%= t(".back") %>
  <% end %>
  <%= button_to manager_reserve_project_complete_path(current_reserve, project_id: @presenter.project), method: :patch, class: "active" do %>
    <%= t(".next_step") %>
    <%= image_tag "arrow-right.svg", alt: t("alt.right_facing_arrow") %>
  <% end %>
</section>
