<tr id="<%= dom_id project %>" class="project">
  <td><strong><%= truncate(project.title, length: 50) %></strong></td>
  <td>
    <%= link_to project.applicant_name,
      edit_manager_reserve_user_path(current_reserve, project.applicant_id)
    %>
  </td>
  <td><%= project.recent_visit_date %></td>
  <td><%= project.project_type %></td>
  <td>
    <%= link_to pluralize(project.visits_count, "visit"),
      manager_reserve_user_activities_path(current_reserve, project.applicant_id)
    %>
  </td>
  <td>
    <%= link_to manager_reserve_project_path(current_reserve, project.id), target: "_top" do %>
      <%= image_tag "arrow-circle-right-heavy-light.svg", height: "20px", width: "20px", alt: t("alt.right_facing_arrow") %>
    <% end %>
  </td>
</tr>
