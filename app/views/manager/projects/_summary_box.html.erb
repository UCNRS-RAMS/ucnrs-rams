<section class="project-summary-box">
  <div class="info-block">
    <div class="w-200">
      <p><%= t(".number") %></p>
      <p class="title"><%= presenter.id %></p>
    </div>
    <div >
      <p><%= t(".reserves") %></p>
      <p class="title"><%= presenter.reserve_names %></p>
    </div>
  </div>
  <div class="info-block">
    <div>
      <p><%= t(".title") %></p>
      <p class="title"><%= presenter.title %></p>
    </div>
  </div>
  <div class="info-block">
    <div class="w-200">
      <p><%= t(".date_created") %></p>
      <p class="title"><%= presenter.created_at %></p>
    </div>
    <div class="w-200">
      <p><%= t(".last_edited") %></p>
      <p class="title"><%= presenter.updated_at %></p>
    </div>
    <div class="w-200">
      <p><%= t(".owner") %></p>
      <p class="title">
        <%= link_to presenter.owner_name,
          edit_manager_reserve_user_path(current_reserve, presenter.owner_id),
          target: "_top" %>
      </p>
    </div>
    <div class="w-200 ">
      <p><%= t(".project_type") %></p>
      <p class="title"><%= presenter.project_type %></p>
    </div>
  </div>
</section>
