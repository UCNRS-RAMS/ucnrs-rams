<turbo-frame id="project-details">
  <section class="project-detail-edit">
    <section class="form-subsection uneditable-visit-project-info">
      <header>
        <h2><%= t(".project_type") %></h2>
      </header>
      <section>
        <h3><%= t(".#{@presenter.project_type}") %></h3>
        <p><%= t(".#{@presenter.project_type}_tag_line") %></p>
      </section>
    </section>
    <section>
      <%= form_with model: @presenter.form, 
        url: manager_reserve_project_detail_url(current_reserve, @presenter.id), 
        method: :put, 
        data: { controller: "turbo-content" }, 
        id: "projects-edit" do |form| 
      %>
        <div class="<%= @presenter.project_type %>">
          <%= render partial: @presenter.partial_name, 
            locals: { form: form, presenter: @presenter } 
          %>
        </div>
      <% end %>
    </section>
  </section>
  <section class="controls">
    <button form="projects-edit" class="active">
      <%= t(".save_changes") %>
    </button>
  </section>
</turbo-frame>
