<div class="card mb-5">
    <div class="card-body" style="background-color:#eee;">
        <p class="text-muted m-0">
            Data is drawn from approved reservation participants with start and end
            dates within the selected date range.
        </p>
    </div>
</div>
<div class="table-responsive">
  <table class="project-funding-report" style="width: 100%;">
    <thead>
      <tr>
        <th colspan="3">Users list by Role</th>
      </tr>
    </thead>
    <tbody>
      <% temp_role = '' %>
      <% data.each do |ap| %>
        <% if temp_role != ap.role %>
          <tr style="background:#eee;">
            <th colspan="3"><%= t("universal.roles.#{ap.role}") %></th>
          </tr>

        <% end %>
        <% temp_role = ap.role %>
        <tr>
          <td><%= link_to( ap.user.full_name, edit_manager_reserve_user_path(current_reserve, ap.user) ) %></td>
          <td><%= mail_to ap.user.email %></td>
          <td><%= ap.institution.name %></td>
        </tr>

      <% end %>
    </tbody>
  </table>
  <br /><br />
</div>