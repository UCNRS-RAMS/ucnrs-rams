<form method="get" data-turbo-action="advance">
  <div class="search-primary">
    <div class="row">
      <div class="row-auto">
        <label for="flex_report_type"><%= t(".flex_report_type") %></label>
        <select id="flex_report_type" name="filter[flex_report_type]" aria-label="show" onchange="this.form.requestSubmit()">
          <%= tag.option t("sitewide.please_select_one"), value: "" %>
          <%= options_for_select(@presenter.flex_report_type_options, @presenter.flex_report_type_filter) %>
        </select>
      </div>
    </div>
    <div class="row">
      <div class="row-auto" id="horizontal-line">
        <label for="date_begin"><%= t(".date_range") %></label>
        <div class="input-with-buttons calendar">
          <input type="date" name="filter[date_begin]" value="<%= @presenter.date_begin_filter %>" onchange="this.form.requestSubmit()">
        </div>
      </div>
      <div class="row-auto">
        <label for="date_end"></label>
        <div class="input-with-buttons calendar">
          <input type="date" name="filter[date_end]" value="<%= @presenter.date_end_filter %>" onchange="this.form.requestSubmit()">
        </div>
      </div>
    </div>
    <div class="row">
      <div class="row-auto">
        <label for="reserve"><%= t(".reserve") %></label>
        <select name="filter[reserve]" aria-label="reserve" onchange="this.form.requestSubmit()">
          <%= tag.option t("sitewide.please_select_one"), value: "" %>
          <%= options_for_select(@presenter.reserve_options, @presenter.reserve_filter) %>
        </select>
      </div>
    </div>
  </div>
</form>
