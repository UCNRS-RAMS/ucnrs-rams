<div>
  <div class="row">
    <div class="form-group col-25">
      <%= form.label :sort_order, t(".sort_order"), class: "form-label" %>
      <%= form.number_field :sort_order, class: "form-input" %>
    </div>
  </div>
  <hr />
  <div class="form-group">
    <%= form.label :name, t(".name"), class: "form-label" %>
    <%= form.text_field :name, class: "form-input" %>
  </div>
  <div class="form-group">
    <%= form.label :content, class: "form-label" %>
    <%= form.rich_text_area :content, class: "form-textarea" %>
    <small><%= t(".description_helper_text") %></small>
  </div>
</div>
