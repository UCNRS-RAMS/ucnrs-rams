<div>
  <div class="row">
    <div class="form-group col-25">
      <%= form.label :sort_order, t(".labels.sort_order"), class: "form-label" %>
      <%= form.number_field :sort_order, class: "form-input" %>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".labels.visible") %></div>
    <div>
      <div class="form-inline">
        <%= form.radio_button(:visible, true) %>
        <%= form.label(:visible_true, t(".labels.enabled"), class: "form-inline-label") %>
      </div>
      <div class="form-inline">
        <%= form.radio_button(:visible, false) %>
        <%= form.label(:visible_false, t(".labels.disabled"), class: "form-inline-label") %>
      </div>
    </div>
  </div>
  <hr />
  <div class="row">
    <div class="form-group">
      <%= form.label :location, t(".labels.question_location"), class: "form-label" %>
      <%= form.select :location, presenter.location_options, { include_blank: "Select one" }, class: "form-input" %>
      <%= tag.small t(".labels.question_location_description") %>
    </div>
  </div>
  <hr />
  <div class="row">
    <div class="form-group col-50">
      <%= form.label :question_type, t(".labels.question_type"), class: "form-label" %>
      <%= form.select :question_type, presenter.question_type_options, {include_blank: "Select one"}, class: "form-input" %>
    </div>
  </div>
  <div class="form-group">
    <%= form.label :question, t(".labels.reserve_question"), class: "form-label" %>
    <%= form.text_area :question, class: "form-textarea" %>
  </div>
  <div class="form-group">
    <%= form.label :statement, t(".labels.additional_information"), class: "form-label" %>
    <%= form.text_area :statement, class: "form-textarea" %>
    <small><%=t(".helper_text.additional_information")%></small>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".labels.answer_required") %></div>
    <div>
      <div class="form-inline">
        <%= form.radio_button(:answer_required, true) %>
        <%= form.label(:answer_required_true, t(".labels.required"), class: "form-inline-label") %>
      </div>
      <div class="form-inline">
        <%= form.radio_button(:answer_required, false) %>
        <%= form.label(:answer_required_false, t(".labels.optional"), class: "form-inline-label") %>
      </div>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".labels.project_type_location") %></div>
    <div>
      <%= form.check_box(:research, {}, 'true', 'false') %>
      <%= form.label(:research, t(".labels.research_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:university_class, {}, 'true', 'false') %>
      <%= form.label(:university_class, t(".labels.class_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:public_use, {}, 'true', 'false') %>
      <%= form.label(:public_use, t(".labels.public_use_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:conference, {}, 'true', 'false') %>
      <%= form.label(:conference, t(".labels.conference_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:housing, {}, 'true', 'false') %>
      <%= form.label(:housing, t(".labels.housing_project"), class: "form-inline-label") %>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".labels.does_this_question_involves") %></div>
    <div>
      <%= form.check_box(:involves_mammals, {}, 'true', 'false') %>
      <%= form.label(:involves_mammals, t(".labels.mammals"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_reptiles, {}, 'true', 'false') %>
      <%= form.label(:involves_reptiles, t(".labels.reptiles"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_amphibians, {}, 'true', 'false') %>
      <%= form.label(:involves_amphibians, t(".labels.amphibians"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_fish, {}, 'true', 'false') %>
      <%= form.label(:involves_fish, t(".labels.fish"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_birds, {}, 'true', 'false') %>
      <%= form.label(:involves_birds, t(".labels.birds"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_plants_fungi_soil, {}, 'true', 'false') %>
      <%= form.label(:involves_plants_fungi_soil, t(".labels.plants_fungi_soil"), class: "form-inline-label") %>
    </div>
    <small><%=t(".helper_text.does_this_question_involves")%></small>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".labels.flag") %></div>
    <div>
      <%= form.check_box(:iacuc_flag, {}, 'true', 'false') %>
      <%= form.label(:iacuc_flag, t(".labels.iacuc"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:drone_flag, {}, 'true', 'false') %>
      <%= form.label(:drone_flag, t(".labels.drone"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:scuba_flag, {}, 'true', 'false') %>
      <%= form.label(:scuba_flag, t(".labels.scuba"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:vertebrate_flag, {}, 'true', 'false') %>
      <%= form.label(:vertebrate_flag, t(".labels.vertebrate"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:threatened_endangered_flag, {}, 'true', 'false') %>
      <%= form.label(:threatened_endangered_flag, t(".labels.threatened"), class: "form-inline-label") %>
    </div>
    <small><%=t(".helper_text.flag")%></small>
  </div>
</div>
