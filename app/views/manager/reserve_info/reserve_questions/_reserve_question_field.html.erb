<div>
  <div class="row">
    <div class="form-group col-25">
      <%= form.label :sort_order, t(".sort_order"), class: "form-label" %>
      <%= form.number_field :sort_order, class: "form-input" %>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".visible") %></div>
    <div>
      <div class="form-inline">
        <%= form.radio_button(:visible, true) %>
        <%= form.label(:visible_true, t(".enabled"), class: "form-inline-label") %>
      </div>
      <div class="form-inline">
        <%= form.radio_button(:visible, false) %>
        <%= form.label(:visible_false, t(".disabled"), class: "form-inline-label") %>
      </div>
    </div>
  </div>
  <hr />
  <div class="row">
    <div class="form-group col-50">
      <%= form.label :location, t(".question_location"), class: "form-label" %>
      <%= form.select :location, presenter.location_options, { include_blank: "Select one" }, class: "form-input" %>
    </div>
  </div>
  <hr />
  <div class="row">
    <div class="form-group col-50">
      <%= form.label :question_type, t(".question_type"), class: "form-label" %>
      <%= form.select :question_type, presenter.question_type_options, {include_blank: "Select one"}, class: "form-input" %>
    </div>
  </div>
  <div class="form-group">
    <%= form.label :question, t(".reserve_question"), class: "form-label" %>
    <%= form.text_area :question, class: "form-textarea" %>
  </div>
  <div class="form-group">
    <%= form.label :statement, t(".additional_information"), class: "form-label" %>
    <%= form.text_area :statement, class: "form-textarea" %>
    <small><%=t(".description_helper_text")%></small>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".answer_required") %></div>
    <div>
      <div class="form-inline">
        <%= form.radio_button(:answer_required, true) %>
        <%= form.label(:answer_required_true, t(".required"), class: "form-inline-label") %>
      </div>
      <div class="form-inline">
        <%= form.radio_button(:answer_required, false) %>
        <%= form.label(:answer_required_false, t(".optional"), class: "form-inline-label") %>
      </div>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t('.project_type_location') %></div>
    <div>
      <%= form.check_box(:research, {}, 'true', 'false') %>
      <%= form.label(:research, t(".research_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:university_class, {}, 'true', 'false') %>
      <%= form.label(:university_class, t(".class_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:public_use, {}, 'true', 'false') %>
      <%= form.label(:public_use, t(".public_use_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:conference, {}, 'true', 'false') %>
      <%= form.label(:conference, t(".conference_project"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:housing, {}, 'true', 'false') %>
      <%= form.label(:housing, t(".housing_project"), class: "form-inline-label") %>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t('.flag') %></div>
    <div>
      <%= form.check_box(:iacuc_flag, {}, 'true', 'false') %>
      <%= form.label(:iacuc_flag, t(".iacuc"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:drone_flag, {}, 'true', 'false') %>
      <%= form.label(:drone_flag, t(".drone"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:scuba_flag, {}, 'true', 'false') %>
      <%= form.label(:scuba_flag, t(".scuba"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:vertebrate_flag, {}, 'true', 'false') %>
      <%= form.label(:vertebrate_flag, t(".vertebrate"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:threatened_endangered_flag, {}, 'true', 'false') %>
      <%= form.label(:threatened_endangered_flag, t(".threatened"), class: "form-inline-label") %>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t('.does_this_question_involves') %></div>
    <div>
      <%= form.check_box(:involves_mammals, {}, 'true', 'false') %>
      <%= form.label(:involves_mammals, t(".mammals"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_reptiles, {}, 'true', 'false') %>
      <%= form.label(:involves_reptiles, t(".reptiles"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_amphibians, {}, 'true', 'false') %>
      <%= form.label(:involves_amphibians, t(".amphibians"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_fish, {}, 'true', 'false') %>
      <%= form.label(:involves_fish, t(".fish"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_birds, {}, 'true', 'false') %>
      <%= form.label(:involves_birds, t(".birds"), class: "form-inline-label") %>
    </div>
    <div>
      <%= form.check_box(:involves_plants_fungus_soil, {}, 'true', 'false') %>
      <%= form.label(:involves_plants_fungus_soil, t(".plants_fungus_soil"), class: "form-inline-label") %>
    </div>
  </div>
</div>
