<section class="content">
  <%= render partial: 'manager/reserve_info/header' %>
  <div>
    <section class="reserve-info-menu">
      <%= render partial: 'manager/reserve_info/menu' %>
    </section>
    <section class="reserve-info">
      <header><%= t(".amenities_and_rates") %></header>
      <section class="reserve-info-subsection">
        <header><%= t(".amenities_list") %></header>
        <p><%= t(".amenities_list_paragraph1") %></p>
        <p><%= t(".amenities_list_paragraph2") %></p>
        <%= render partial: "amenities", locals: { amenities: @presenter.amenities } %>
      </section>
      <section class="reserve-info-subsection">
        <header><%= t(".rate_categories") %></header>
        <p><%= t(".rate_categories_paragraph1") %></p>
        <%= render partial: "amenity_rate_categories", locals: { amenity_rate_categories: @presenter.amenity_rate_categories } %>
      </section>
      <section class="reserve-info-subsection">
        <header><%= t(".amenity_rates") %></header>
        <p><%= t(".amenity_rates_paragraph1") %></p>
        <%= render partial: "amenity_rates", locals: { amenity_rates: @presenter.amenity_rates } %>
      </section>
    </section>
  </div>
</section>
