<div>
  <div class="form-group">
    <div class="form-inline">
      <%= form.radio_button(:disable, false) %>
      <%= form.label(:disable_false, t(".enabled"), class: "form-label") %>
    </div>
    <div class="form-inline">
      <%= form.radio_button(:disable, true) %>
      <%= form.label(:disable_true, t(".disabled"), class: "form-label") %>
    </div>
  </div>
  <div class="row">
    <div class="form-group col-25">
      <%= form.label :sort_order, t(".sort_order"), class: "form-label" %>
      <%= form.number_field :sort_order, class: "form-input" %>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".selected_at_default") %></div>
    <div>
      <div class="form-inline">
        <%= form.radio_button(:default_select, true) %>
        <%= form.label(:default_select_true, t("yes"), class: "form-label") %>
      </div>
      <div class="form-inline">
        <%= form.radio_button(:default_select, false) %>
        <%= form.label(:default_select_false, t("no"), class: "form-label") %>
      </div>
    </div>
  </div>

  <hr />

  <div class="row">
    <div class="form-group col-50">
      <%= form.label :group_number, t(".amenity_group"), class: "form-label" %>
      <%= form.select :group_number, presenter.amenities_group_options, { include_blank: t(".select_one") }, class: "form-input" %>
      <small><%=t(".description_amenity_type_text")%></small>
    </div>
  </div>
  <div class="form-group">
    <%= form.label :title, t(".name_of_amenity"), class: "form-label" %>
    <%= form.text_field :title, class: "form-input" %>
  </div>
  <div class="form-group">
    <%= form.label :comment, t(".description_of_amenity"), class: "form-label" %>
    <%= form.text_area :comment, class: "form-textarea" %>
    <small><%=t(".description_helper_text")%></small>
  </div>
  <div class="row">
    <div class="form-group col-50">
      <%= form.label :total_capacity, t(".maximum_capacity"), class: "form-label" %>
      <%= form.number_field :total_capacity, class: "form-input" %>
      <small><%=t(".description_capacity_text")%></small>
    </div>
  </div>
  <div class="row">
    <div class="col form-group">
      <%= form.label :listing_photo, "Amenity listing photo", class: "form-label" %>
      <div class="reserve-pictures">
        <%= image_tag @presenter.listing_photo, height: "100" %>
        <%= form.file_field :listing_photo %>
        <%= form.hidden_field :listing_photo_cache %>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="form-group">
      <%= form.label :units_type, t(".amenity_units_type"), class: "form-label" %>
      <%= form.select :units_type, presenter.units_type_options, { include_blank: t(".select_one") }, class: "form-input" %>
      <small><%=t(".description_units_type_text")%></small>
    </div>
    <div class="form-group">
      <%= form.label :time_type, t(".amenity_time_interval"), class: "form-label" %>
      <%= form.select :time_type, presenter.time_type_options, { include_blank: t(".select_one") }, class: "form-input" %>
      <small><%=t(".description_time_type_text")%></small>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".visible") %></div>
    <div>
      <div class="form-inline">
        <%= form.radio_button(:visible, true) %>
        <%= form.label(:visible_true, t("yes"), class: "form-label") %>
      </div>
      <div class="form-inline">
        <%= form.radio_button(:visible, false) %>
        <%= form.label(:visible_false, t("no"), class: "form-label") %>
      </div>
    </div>
  </div>
  <div class="form-group">
    <div class="form-label"><%= t(".invoiceable") %></div>
    <div>
      <div class="form-inline">
        <%= form.radio_button(:show_on_invoice, true) %>
        <%= form.label(:show_on_invoice_true, t("yes"), class: "form-label") %>
      </div>
      <div class="form-inline">
        <%= form.radio_button(:show_on_invoice, false) %>
        <%= form.label(:show_on_invoice_false, t("no"), class: "form-label") %>
      </div>
    </div>
    <small><%=t(".description_invoiceable_text")%></small>
  </div>
</div>
