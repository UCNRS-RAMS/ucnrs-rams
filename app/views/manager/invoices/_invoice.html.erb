<tr class="invoice" id="<%= "invoice-#{ invoice.id }" %>">
  <td><%= invoice.invoice_id %></td>
  <td><%= invoice.invoiced_on %></td>
  <td><%= invoice.user_full_name %></td>
  <td><%= invoice.project_title %></td>
  <td><%= invoice.amount %></td>
  <td><%= invoice.invoice_status %></td>
  <td>
    <%= link_to manager_reserve_visit_invoice_path(reserve_id: invoice.reserve_id, visit_id: invoice.visit_id, id: invoice.id) do %>
      <%= image_tag "arrow-circle-right-heavy-light.svg", height: "20px", width: "20px", alt: t(".alt.right_facing_arrow")  %>
    <% end %>
  </td>
</tr>
