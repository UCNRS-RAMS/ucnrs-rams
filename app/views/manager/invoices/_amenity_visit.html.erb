<%= fields_for "amenity_visit[#{amenity_visit.id}]", amenity_visit do |f| %>
  <div class="table-row d-flex" data-controller="invoices">
    <div class="right-spacer">
      <%= f.check_box "checked", checked: true, data: { action: "change->invoices#toggle change->invoices#calculateSubtotal", "invoices-target": "checkBox" } %>
      <strong><%= presenter.title %></strong>
    </div>
    <%= f.hidden_field "amenity_visit_id", value: amenity_visit.id %>
    <%= f.hidden_field :status, value: "approved" %>
    <div class="d-flex">
      <div class="d-flex text-field-div right-spacer">
        <div class="d-flex-column">
          <%= f.label :arrives, for: "arrives#{amenity_visit.id}", class: "text-center" %>
          <%= f.date_field :arrives, id: "arrives#{amenity_visit.id}", class: "select-field", onclick: "showPicker()", data: { action: "change->invoices#calculateSubtotal change->invoices#calculateTotal", "invoices-target": "arrives" } %>
        </div>
        <%= t(".spacer") %>
        <div class="d-flex-column">
          <%= f.label :departs, for: "departs#{amenity_visit.id}", class: "text-center" %>
          <%= f.date_field :departs, id: "departs#{amenity_visit.id}", class: "select-field", onclick: "showPicker()", data: { action: "change->invoices#calculateSubtotal change->invoices#calculateTotal", "invoices-target": "departs" } %>
        </div>
        <div class="days">
          <strong class="left-spacer right-spacer"><%= t(".left_bracket") %>
            <%= presenter.period.humanize %>
            <span data-invoices-target="days"><%= amenity_visit.total_days %></span>
            <%= t(".right_bracket") %></strong>
        </div>
      </div>
      <div class="d-flex right-spacer">
      </div>
      <div class="d-flex text-field-div right-spacer">
        <%= f.label presenter.unit, for: "number_of_people#{amenity_visit.id}" %>
        <%= f.number_field :number_of_people, min: 1, id: "number_of_people#{amenity_visit.id}", data: { action: "input->invoices#calculateSubtotal input->invoices#calculateTotal", "invoices-target": "unit" }, class: "input-field" %>
      </div>
      <div class="text-field-div"><%= f.select :amenity_rate_id, options_for_select(presenter.amenity_rate_options, presenter.selected_amenity_rate_id), {}, class: "select-field", "data-invoices-target": "rate",  "data-action": "change->invoices#calculateSubtotal change->invoices#calculateTotal" %></div>
    </div>
    <div class="text-center">
      <strong><%= t(".dollar") %> <span data-invoices-target="subTotal" class="subtotal"><%= amenity_visit.total %></span></strong>
    </div>
  </div>
<% end %>
