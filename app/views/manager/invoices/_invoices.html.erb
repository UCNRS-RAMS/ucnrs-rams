<turbo-frame id="invoices">
  <table class="invoices-table table-style1">
    <thead>
      <tr>
        <th class="invoice-number"><%= t(".invoice_number") %></th>
        <th class="invoice-date"><%= t(".invoice_date") %></th>
        <th><%= t(".user") %></th>
        <th><%= t(".project") %></th>
        <th class="balance"><%= t(".balance_due") %></th>
        <th><%= t(".status") %></th>
        <th></th>
      </tr>
    </thead>
      <%= render partial: "invoice", collection: invoices %>
  </table>
</turbo-frame>
