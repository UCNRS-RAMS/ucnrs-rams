<section class="project-team p-bottom">
  <h2 class="main-header"><%= t(".user_visits", size: presenter.user_visits.sum(&:count)) %></h2>
    <%= link_to t(".edit_visitor"), manager_reserve_visit_user_visits_path(visit_id: presenter.id, reserve_id: presenter.reserve_id),
        data: { controller: "tab-bar", action: "click->tab-bar#selectTab", "tab-bar-id-param": "visitors", } %>
  <table id="team-summary-table" class="summary-table">
    <thead>
      <tr>
        <th><%= t(".name") %></th>
        <th><%= t(".institution") %></th>
        <th><%= t(".role") %></th>
        <th><%= t(".project_role") %></th>
        <th><%= t(".dates_of_use") %></th>
      </tr>
    </thead>
    <tbody>
      <%= render partial: "manager/visits/summary/user_visit", collection: presenter.user_visits %>
    </tbody>
  </table>
</section>
