<% orcid_authenticated_alt_text = local_assigns.fetch(:orcid_authenticated_alt_text, t("devise.registrations.user_fields.alt.orcid_id")) %>
<% orcid_placeholder = local_assigns.fetch(:orcid_placeholder, t("devise.registrations.user_fields.placeholders.orcid")) %>

<div class="field small orcid">
  <%= f.label :orcid, orcid_label %>

  <% show_read_only_orcid = f.object.orcid_authenticated? && f.object.orcid.present? && f.object.errors[:orcid].blank? %>

  <% if show_read_only_orcid %>
    <% orcid_uri = orcid_display_uri(f.object.orcid) %>
    <% if orcid_uri.present? %>
      <p class="orcid-authenticated">
        <%= image_tag("orcid-icon.svg", alt: orcid_authenticated_alt_text) %>
        <%= link_to orcid_uri, orcid_uri, target: "_blank", rel: "noopener" %>
      </p>
      <%= f.hidden_field :orcid %>
    <% else %>
      <%= f.text_field :orcid, placeholder: orcid_placeholder %>
    <% end %>
  <% else %>
    <%= f.text_field :orcid, placeholder: orcid_placeholder %>
  <% end %>

  <p class="helper-text">
    <%= link_to orcid_link_text, orcid_url, target: "_blank" %>
  </p>
</div>
