<tr id="<%= dom_id user %>">
  <td><strong><%= user.full_name %></strong></td>
  <td><%= user.institution_name %></td>
  <td><%= t("universal.roles")[:"#{user.role}"] %></td>
  <td><%= user.number_of_project_members %></td>
  <td><%= user.number_of_visits %></td>
  <td>
    <%= link_to "#" do %>
      <%= image_tag "arrow-right-circle.svg", alt: t("alt.right_facing_arrow"), height: "20", width: "20" %>
    <% end %>
  </td>
</tr>
