<section class="amenity_group" data-controller = "amenity-category" >
  <header data-action="click->amenity-category#toggle">
    <h3><%= group_label %></h3>
    <%= image_tag "icon-maximize.svg", size: "24x24", data: { "amenity-category-target": "maxImage" } %>
    <%= image_tag "icon-minimize.svg", size: "24x24", data: { "amenity-category-target": "minImage" } %>
  </header>
  <div data-amenity-category-target = "amenitiesDiv" >
    <% amenities.each do |amenity| %>
      <%= fields_for "visit[amenities][#{ amenity.amenity_id }]", amenity.form.first do |form| %>
        <%= render partial: "visits/amenities/amenity",
          locals: {
            form: form,
            presenter: amenity,
            group_label: group_label,
            forms: amenity.form,
          }
        %>
      <% end %>
    <% end %>
  </div>
</section>
