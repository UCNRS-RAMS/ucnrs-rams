<div class="amenity">
  <%= check_box_tag "#{form.object_name}[amenity_id]", amenity.amenity_id, amenity.checked, id: amenity.checkbox_id %>
  <label for="<%= amenity.checkbox_id %>">
    <%= form.hidden_field :amenity_visit_id %>
    <img src="<%= amenity.image_url %>"/>
    <div class="content">
      <h3><%= amenity.title %></h3>
      <p><%= amenity.description %></p>
      <%= link_to t(".more_info"), "#" %>
    </div>
    <div class="booking">
      <div class="field">
        <%= form.label :arrives_on, t(".date_of_arrival") %>
        <%= form.date_field :arrives_on, value: form.object.arrives_on %>
      </div>
      <div class="field">
        <%= form.label :departs_on, t(".date_of_departure") %>
        <%= form.date_field :departs_on, value: form.object.departs_on %>
      </div>
      <div class="field">
        <%= form.label :amenity_rate_id, "#{t(".rate")}#{t(".rate_period", unit: amenity.unit, period: amenity.period)}" %>
        <%= form.collection_select :amenity_rate_id, amenity.rates, :id, :label %> 
      </div>
      <div class="field" data-controller="counter">
        <label><%= t(".number_of_people") %></label>
        <input type="button" data-action="click->counter#decrement" value="-"/>
        <%= form.text_field :number_of_people, data: { "counter-target": "output" } %>
        <input type="button" data-action="click->counter#increment" value="+"/>
      </div>
      <div class="field">
        <label><%= t(".subtotal") %><%=t(".rate_period", unit: amenity.unit, period: amenity.period) %></label>
        <p>$120.00</p>
      </div>
    </div>
  </label>
</div>
