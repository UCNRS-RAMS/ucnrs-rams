<div class="question">
  <span class="question_text"><%= question.question %><span class="clr-red><%= " *" if question.answer_required %></span> </span>
  <div class="field">
    <%= f.text_area :text_answer, rows:10, aria: { label: t(".aria_label_for", question: question.id) }, class: "text-area" %>
  </div>
</div>
