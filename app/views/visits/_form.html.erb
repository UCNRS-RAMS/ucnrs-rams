<section>
  <fieldset data-controller="value-projection turbo-content" data-value-projection-projected-value="<%= form.object.project_type %>">
    <legend><%= t(".titles.purpose") %></legend>

    <fieldset data-purpose="project_type">
      <%= form.label :project_type, "" %>
      <% @page.project_type_options.each do |value|%>
        <label for="project-type-<%= value %>">
          <%= form.radio_button :project_type, value, id: "project-type-#{value}", data: { action: "click->value-projection#change click->turbo-content#change" }, checked: form.object.project_type == value %>
          <span><%= t(".project_type_options.labels.#{value}") %></span>
          <span><%= t(".project_type_options.explanation.#{value}") %></span>
        </label>
      <% end %>
    </fieldset>

    <div class="field project_select">
      <%= form.label :project, t(".labels.project"), for: "visit_project_id" %>
      <%= render partial: "visits/projects/projects_select", locals: { page: @page.projects } %>
      <%= link_to t(".links.create_a_new_project"), "/projects/new" %>
    </div>

    <div class="field public_use_select">
      <%= form.label :public_use_category, t(".labels.public_use_category") %>
      <%= form.collection_select(
            :public_use_category,
            @page.public_use_categories,
            :to_s,
            @page.translate_in(".public_use_options.labels"),
            { selected: form.object.public_use_category }
          )
      %>
    </div>

    <%= form.label :purpose_of_visit, t(".labels.purpose_of_visit") %>
    <%= form.text_area :purpose_of_visit %>
  </fieldset>

  <span data-controller="followup-content">
    <fieldset class="reserve-info">
      <legend><%= t(".titles.reserve") %> <%= link_to t(".links.browse_reserves"), "#" %></legend>

      <div class="field">
        <%= form.label :reserve, t(".labels.reserve"), for: "visit_reserve_id" %>
        <%= form.collection_select(:reserve_id, @page.reserve_options, :id, :pulldown_name, { include_blank: true }, { data: { action: "change-> followup-content#change" } }) %>
      </div>

      <div class="date-range-select">
        <div class="field">
          <%= form.label :start_date, t(".labels.arrival") %>
          <div class="date-time-select">
            <%= form.date_field(:start_date, value: @page.start_date, min: Date.today) %>
            <%= form.time_field(:start_time, value: @page.start_time, aria: { label: t(".aria.arrival_time") }) %>
          </div>
        </div>

        <span class="separator"></span>

        <div class="field">
          <%= form.label :end_date, t(".labels.departure") %>
          <div class="date-time-select">
            <%= form.date_field(:end_date, value: @page.end_date, min: Date.today) %>
            <%= form.time_field(:end_time, value: @page.end_time, aria: { label: t(".aria.departure_time") }) %>
          </div>
        </div>
      </div>

      <div class="flex-break"></div>

      <div data-followup-content-target="destination" data-followup-content-url-value="<%= visits_reserve_input_url("VALUE") %>" class="reserve-specific-fields">
        <%= render partial: "visits/reserve_inputs/fields", locals: { form_values: @page.form, page: @page } %>
      </div>
    </fieldset>

    <fieldset class="amenities">
      <legend><%= t(".titles.amenities") %><span><%= t(".titles.amenities_subtitle") %></span></legend>
      <section class="amenity-options" data-followup-content-target="destination" data-followup-content-url-value="<%= visits_amenities_url(reserve_id: "VALUE") %>">
        <% @page.amenities.each do |amenity| %>
          <%= fields_for "visit[amenities][#{ amenity.amenity_id }]", amenity.form do |form| %>
            <%= render partial: "visits/amenities/amenity", locals: { form: form, page: amenity } %>
          <% end %>
        <% end %>
      </section>
    </fieldset>
  </span>

  <fieldset>
    <%= link_to  "#" do %>
      <%= image_tag "arrow-left.svg", height: "24px", width: "24px", alt: t(".alt_text.left_arrow") %>
      <%= t(".links.go_back") %>
    <% end %>
    <%= form.submit(t(".labels.next_page.visitors")) %>
  </fieldset>
</section>
