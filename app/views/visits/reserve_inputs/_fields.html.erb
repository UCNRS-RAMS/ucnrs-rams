<% if presenter.reserve %>
  <%= tag.div simple_format(presenter.alert_message), class: "reserve-message" if presenter.alert_message.present? %>

  <div class="field">
    <label for="reserve-special-needs"><%= t(".labels.special_needs") %></label>
    <p class="special-needs-statement"><%= presenter.special_needs_statement %></p>
    <textarea name="visit[special_needs]" id="reserve-special-needs"><%= form_values.special_needs %></textarea>
  </div>

  <div class="field">
    <label for="visit_study_area"><%= t(".labels.study_area") %></label>
    <input name="visit[study_area]" id="visit_study_area" value="<%= form_values.study_area %>"/>
    <small class="label-description"><%= t(".labels.study_area_description") %></small>
  </div>
<% end %>
