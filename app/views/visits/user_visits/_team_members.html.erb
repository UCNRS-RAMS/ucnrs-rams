<turbo-frame id="add-visitor">
  <div class="d-flex">
    <%= render partial: 'visits/user_visits/links' %>
    <% if presenter.can_add_project_user? %>
      <%= link_to t(".new_team_member"), project_team_memberships_path(presenter.visit.project.id), target: "_blank" %>
    <%end%>  
  </div>
  <section id="add-team-member">
    <table class="user-visits-table">
      <tbody>
        <%= render partial: "visits/user_visits/team_member", locals: { presenter: presenter, team_members: presenter.project_team_members } %>
      </tbody>
    </table>
  </section>
</turbo-frame>
