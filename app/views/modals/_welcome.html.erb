<div class="modal-content welcome" role="dialog" aria-labelledby="dialog-title" aria-describedby="modal-description">
  <%= image_tag "latest-news-background.jpg", class: "main-image" %>
  <p class="screenreader-text" id="modal-description"><%= t(".accessible_description") %></p>
  <section class="text">
    <h1 id="dialog-title"><%= t(".title") %></h1>
    <p id="dialog-description"><%= t(".content") %></p>
  </section>
  <section class="buttons">
    <button class="active" data-action="click->modal#close">
      <%= t(".continue") %>
      <%= image_tag "arrow-right.svg" %>
    </button>
  </section>
</div>
