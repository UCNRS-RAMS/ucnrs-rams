<section class="calendar-visit">
  <header>
    <h2><%= t("universal.project.project_types.#{visit.project_type}") %> Visit</h2>
  </header>
  <div class="calendar-visit-body">
    <div>
      <p><%= "@ #{visit.reserve_name}" %></p>
      <p><%= t("universal.roles.#{visit.user_role}") %> - <%= visit.institution_name %></p>
    </div>

    <div class="visit-status">
      <%= tag.span t("universal.visit.statuses.#{visit.status_class}"), class: "pill #{visit.status_class}" %>
      <%= tag.p pluralize(visit.visitor_count_on_date(begin_date), t("sitewide.visitor")) %>
    </div>
  </div>
</section>
