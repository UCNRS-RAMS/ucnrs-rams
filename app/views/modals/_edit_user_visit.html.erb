<turbo-frame id="modal-content">
  <div class="modal-content" data-modal-target="dialog openOnLoad" data-controller="user-days">
    <p class="screenreader-text">
      <span id="modal-title"><%= t(".title") %></span>
      <span id="modal-description"><%= t(".accessible_description") %></span>
    </p>
    <div class="close">
      <%= image_tag "x.svg", height: "16px", width: "16px",
        id: "x-icon",
        data: { action: "click->modal#close" },
        alt: t("alt.icon_x")
      %>
    </div>

    <%= form_with model: presenter.form, url: presenter.user_visit_form_path, method: "patch" do |form| %>
      <%= form.hidden_field :id %>
      <%= form.hidden_field :count, data: { "user-days-target": "count" } %>

      <section>
        <header class="modal-header">
          <h2><%= t(".title") %></h2>
        </header>
        <div class="field">
          <%= form.label :role %>
          <%= form.select :role, presenter.user_role_options %>
        </div>
        <% if presenter.guest_user? %>
          <div class="field">
            <%= form.label :guest_name %>
            <%= form.text_field :guest_name %>
          </div>
        <% elsif presenter.group_user? %>
          <div class="field">
            <%= form.label :count %>
            <%= form.text_field :count, data: { "user-days-target": "count", action: "input->user-days#countChange"} %>
          </div>
        <% end %>
        <%= render partial: presenter.institution_fields_path, locals: { presenter: presenter, form: form }%>

        <div class="date-range-select">
          <div class="field">
            <%= form.label :arrives_at %>
            <%= form.date_field :arrives_at, data: {"user-days-target": "arrivesAt", action: "input->user-days#calculate" } %>
          </div>
          <span class="separator"></span>
          <div class="field">
            <%= form.label :departs_at %>
            <%= form.date_field :departs_at, data: {"user-days-target": "departsAt", action: "input->user-days#calculate"} %>
          </div>
        </div>

        <%= render partial: presenter.user_days_partial, locals: { presenter: presenter, form: form } %>
      </section>
      <section class="buttons">
        <%= link_to t("cancel"), "#", class: "close", data: { action: "click->modal#close" } %>
        <%= button_tag t("update"), class: "active", type: "submit" %>
      </section>
    <% end %>
  </div>
</turbo-frame>
