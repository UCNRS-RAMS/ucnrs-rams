<section data-controller="state-select-options">
  <div class="field">
    <%= f.label :name, I18n.t(".institutions.labels.name") %>
    <%= f.text_field :name, placeholder: @page.name_placeholder, required: true %> 
  </div>
  <div class="field">
    <%= f.label :institution_type, I18n.t(".institutions.labels.institution_type") %>
    <%= f.select :institution_type, @page.institution_type_options, { prompt: I18n.t(".forms.select_one") }, required: true %>
  </div>
  <div class="field">
    <%= f.label :city, I18n.t(".institutions.labels.city") %>
    <%= f.text_field :city, class: "form-control form-control-sm", placeholder: @page.city_placeholder, required: true %> 
  </div>
  <div class="field" >
    <%= f.label :country_id, I18n.t(".institutions.labels.country") %>
    <%= f.collection_select(:country_id, Country.alphabetical_by_name, :id, :name, { prompt: I18n.t(".forms.select_one") }, { required:true, data: { action: "state-select-options#handleSelectChange", url: states_url } } ) %>
  </div>
  <div class="field">
    <%= f.label :state_id, I18n.t(".institutions.labels.state") %>
    <%= f.collection_select(:state_id, State.alphabetical_by_name, :id, :name, { prompt: I18n.t(".forms.select_one") }, { data: { state_select_options_target: "states" } } ) %>
  </div>
</section>
