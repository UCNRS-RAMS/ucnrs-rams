<div class="container">
  <section class="content">
    <header>
      <h1 class="invoice-title"><%= @presenter.title %></h1>
    </header>
    <turbo-frame id="invoice-details">
      <%= render partial: "visit_info", locals: { presenter: @presenter } %>
      <%= render partial: "invoice_recipients", locals: { recipients: @presenter.recipients } %>
      <%= render partial: "amenity_visits", locals: { amenity_visits: @presenter.amenity_visits } %>
      <% if @presenter.invoice_payments.present? %>
        <%= render partial: "invoice_payments", locals: { invoice_payments: @presenter.invoice_payments } %>
      <% end %>
      <%= render partial: "balance", locals: { presenter: @presenter } %>
      <%= render partial: "notes", locals: { presenter: @presenter } %>
    </turbo-frame>
  </section>
</div>
