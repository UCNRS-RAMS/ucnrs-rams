<section class="invoice-payments subsection">
  <header>
    <h3><%= t(".payments") %></h3>
  </header>
  <table id="invoice-payments-table">
    <thead>
      <tr>
        <th class="payment-date"><%= t(".date") %></th>
        <th class="payment-note"><%= t(".note") %></th>
        <th class="payment-subtotal"><%= t(".amount") %></th>
      </tr>
    </thead>
    <tbody>
      <%= render partial: "invoice_payment", collection: invoice_payments %>
    </tbody>
    <tfoot>
      <tr>
        <td><strong><%= t(".subtotal") %></strong></td>
        <td></td>
        <td class="payment-subtotal">
          <strong><%= number_to_currency -(invoice_payments.sum(&:amount)) %></strong>
        </td>
      </tr>
    </tfoot>
  </table>
</section>
