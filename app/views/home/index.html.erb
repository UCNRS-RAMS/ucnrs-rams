<section class="content">
  <section class="visits">
    <%= render partial: @presenter.partial_name, locals: { presenter: @presenter } %>
  </section>
  <%= turbo_frame_tag "invoice" do %>
    <section class="invoices">
      <header>
        <h1><%= t(".invoices.title") %></h1>
        <%= form_with url: root_path, method: :get, data: { "turbo-frame": "invoice", "turbo-action": "advance" } do %>
          <select id="invoice_status" name="invoice_filter" aria-label="invoice_filter" onchange="this.form.requestSubmit()">
            <optgroup label="<%= t(".labels.by") %>">
              <% @presenter.invoice_filter_options.each do |key, value| %>
                <option <%= @presenter.invoice_selected(value) %> value="<%= value %>"><%= key.humanize %></option>
              <% end %>
            </optgroup>
            <optgroup label="<%= t(".labels.by_reserve") %>">
              <% @presenter.invoice_reserve_list.each do |key, value| %>
                <option <%= @presenter.invoice_selected("reserve_#{value}") %> value="reserve_<%= value %>"><%= key %></option>
              <% end %>
            </optgroup>
          </select>
        <% end %>
      </header>
      <table class="invoices">
        <%= render partial: "invoice", collection: @presenter.invoices %>
      </table>
      <%= paginate @presenter.invoice_scope, param_name: :invoice_page, data: { "turbo-action": "advance" } %>
    </section>
  <% end %>

</section>

<section class="news">
  <header>
    <%= t(".latest_news") %>
    <%= link_to t(".view_all"), "#" %>
  </header>

  <section class="articles">
    <%= render partial: "news_article", collection: @presenter.news_articles %>
  </section>
</section>

<% if session[:welcome].nil? && session[:welcome] = true %>
  <% content_for :modal do %>
    <%= render partial: "modals/welcome" %>
  <% end %>
<% end %>
