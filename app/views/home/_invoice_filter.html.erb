<select id="invoice_status" name="invoice_filter"
  aria-label="invoice_filter" onchange="this.form.requestSubmit()"
>
  <optgroup label="<%= t(".labels.by") %>">
    <% presenter.invoice_filter_options.each do |key, value| %>
      <%= tag.option key.humanize, value: value,
        selected: presenter.invoice_selected(value).present?
      %>
    <% end %>
  </optgroup>
  <optgroup label="<%= t(".labels.by_reserve") %>">
    <% presenter.invoice_reserve_list.each do |key, value| %>
      <%= tag.option key, value: "reserve_#{value}",
        selected: presenter.invoice_selected("reserve_#{value}").present?
      %>
    <% end %>
  </optgroup>
</select>
