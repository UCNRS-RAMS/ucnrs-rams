<svg height="<%= presenter.size %>" width="<%= presenter.size %>" viewBox="0 0 100 100">
  <defs>
    <% if presenter.use_checkmark %>
      <polyline
        id="content-<%= presenter.number %>"
        points="74 32 41 65 26 50"
        fill="white"
        stroke="black"
        stroke-width="7"
      />
    <% else %>
      <text
        id="content-<%= presenter.number %>"
        font-size="60px"
        font-weight="700"
        text-anchor="middle"
        x="50"
        y="50"
        dy="0.37em"
      >
        <%= presenter.number %>
      </text>
    <% end %>
    <mask id="invert-<%= presenter.number %>" maskContentUnits="userSpaceOnUse">
      <rect
        x="0"
        y="0"
        width="100%"
        height="100%"
        stroke-width="0"
        fill="white"
      />
      <use href="#content-<%= presenter.number %>" fill="black"/>
    </mask>
  </defs>
  <circle
    cx="50%"
    cy="50%"
    r="47"
    fill="<%= presenter.color %>"
    stroke="<%= presenter.color %>"
    fill-opacity="<%= presenter.fill_opacity %>"
    stroke-width="6"
    <% if presenter.invert %>
      mask="url(#invert-<%= presenter.number %>)"
    <% end %>
  />
  <% if !presenter.invert %>
    <use href="#content-<%= presenter.number %>" fill="<%= presenter.color %>" />
  <% end %>
</svg>
