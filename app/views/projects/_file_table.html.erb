<table id="funding-summary-table" class="summary-table">
  <thead>
    <tr>
      <th><%= t(".file_name") %></th>
      <th><%= t(".date") %></th>
    </tr>
  </thead>
  <tbody>
    <% if presenter.project.files.present? %>
      <%= render partial: "projects/file", collection: presenter.project.files %>
    <% else %>
      <td colspan="2" class="empty">No Files</td>
    <% end %>
  </tbody>
</table>
