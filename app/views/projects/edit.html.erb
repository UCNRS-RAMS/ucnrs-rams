<% content_for(:title) { t(".title") } %>
<%= render partial: "projects/steps", locals: { presenter: @presenter } %>

<section class="project-form form-container">
  <header>
    <h1><%= t(".title") %></h1>
  </header>
  <%= form_with model: @presenter.form, url: project_url(@presenter.id), data: { controller: "turbo-content" },
    method: :put, id: "projects-edit" do |form|
  %>
    <%= form.hidden_field :id %>
    <section class="form-subsection">
      <header>
        <h2><%= t(".project_type_options.title") %></h2>
      </header>
      <% if @presenter.able_to_edit_project_type? %>
        <section class="project-type-options" data-controller="value-projection"
          data-value-projection-projected-value="<%= form.object.project_type %>">
          <% @presenter.project_type_options.each do |project_type| %>
            <label for="project-type-<%= project_type %>">
              <%= form.radio_button :project_type, project_type, id: "project-type-#{project_type}",
                data: { action: "click->turbo-content#change click->value-projection#change" },
                checked: form.object.project_type.to_s == project_type.to_s
              %>
              <div class="project-type-label">
                <h3><%= t(".project_type_options.labels.#{project_type}") %></h3>
                <p><%= t(".project_type_options.explanation.#{project_type}") %></p>
              </div>
            </label>
          <% end %>
        </section>
      <% else %>
        <section class="uneditable-visit-project-info">
          <h3><%= t(".project_type_options.labels.#{@presenter.project_type}") %></h3>
          <p><%= t(".project_type_options.explanation.#{@presenter.project_type}") %></p>
        </section>
      <% end %>
    </section>

    <%= turbo_frame_tag "project_type_form", data: { pattern: new_project_path(project_type: "VALUE"),
      "turbo-content-target": "destination" } do
    %>
      <div class="<%= @presenter.project_type %>">
        <%= render partial: @presenter.partial_name, locals: {
          form: form,
          presenter: @presenter
        } %>
      </div>
    <% end %>
  <% end %>
</section>

<section class="controls">
  <button form="projects-edit" class="active">
    <%= t(@presenter.current_step_name) %>
    <%= image_tag "arrow-right.svg", alt: t(".alt.right_facing_arrow") %>
  </button>
</section>

<% content_for :modal do %>
  <%= render partial: "modals/empty" %>
<% end %>
