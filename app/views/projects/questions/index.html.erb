<% content_for(:title) { t(".title") } %>
<%= render partial: "projects/steps", locals: { presenter: @presenter } %>

<section>
  <h1><%=t(".title")%></h1>
</section>

<%= form_with model: @presenter.form, url: project_answers_path(@presenter.project), id: "questions" do |form| %>
  <% if @presenter.has_questions_for_project? %>
    <section class="questions">
      <% @presenter.questions_by_authority.each do |authority, questions| %>
        <div class="<%= authority %>_questions">
          <h2><%= t(".authority.#{authority}") %></h2>
          <ul>
            <% questions.each do |permit| %>
              <%= fields_for "project[answers][#{permit.id}]", permit.form do |f| %>
                <li data-controller="value-projection" data-value-projection-projected-value="<%= f.object.answer %>">
                  <div class="question">
                    <p><%= permit.question %></p>
                    <div class="answers">
                      <%= f.radio_button :answer, "1", data: { action: "change->value-projection#change" } %>
                      <%= f.label :answer, t(".have_permit"), for: "project_answers_#{permit.id}_answer_1" %>
                      <%= f.radio_button :answer, "0", data: { action: "change->value-projection#change" } %>
                      <%= f.label :answer, t(".have_no_permit"), for: "project_answers_#{permit.id}_answer_0" %>
                    </div>
                  </div>
                  <div class="description">
                    <p><%= permit.description %></p>
                    <ul>
                      <% permit.urls.each do |url, description| %>
                        <li><%= link_to description, url, target: "_blank" %></li>
                      <% end %>
                    </ul>
                  </div>
                </li>
              <% end%>
            <% end %>
          </ul>
        </div>
      <% end %>
    </section>
    <section class="approved_questions">
      <div class="field">
        <%= form.label :approved_permits %>
        <p>
        <%= form.text_area :approved_permits %>
        <span class="explanation"><%= t(".permit_statement") %></span>
        </p>
      </div>
    </section>
  <% else %>
    <section>
      <input name="project[no_questions]" value="" type="hidden"/>
      <p><%= t(".no_questions") %></p>
    </section>
  <% end %>
<% end %>

<section class="controls">
  <%= link_to project_team_memberships_path(@presenter.project) do %>
    <%= image_tag "arrow-left-blue.svg", height: "16px", width: "16px", alt: t(".alt.left_facing_arrow") %>
    <%= t(".back") %>
  <% end %>
  <button form="questions" class="active" data-turbo="false">
    <%= t(".next_step") %>
    <%= image_tag "arrow-right.svg", alt: t(".alt.right_facing_arrow") %>
  </button>
</section>
