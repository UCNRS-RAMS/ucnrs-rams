<section class="project-team">
  <h2 class="main-header"><%= t(".project_team", size: presenter.team_memberships.size) %></h2>
  <%= link_to t(".edit_team"), project_team_memberships_path(presenter.project_id) %>
  <table id="team-summary-table" class="summary-table">
    <thead>
      <tr>
        <th><%= t(".name") %></th>
        <th><%= t(".institution") %></th>
        <th><%= t(".project_role") %></th>
      </tr>
      <thead>
      <tbody>
        <%= render partial: "projects/team_membership", collection: presenter.team_memberships %>
      </tbody>
  </table>
</section>
