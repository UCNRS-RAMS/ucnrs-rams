<% if presenter.have_reserve_questions_for_visit? %>
  <section class="questions">
    <header>
      <h2 class="main-header" style="font-size: 1.5em; font-weight: 500;">
        <%= t(".visit_reserve_questions") %>
      </h2>
    </header>
    <% presenter.reserve_questions_by_reserve.each do |reserve, questions| %>
      <%= render partial:  "mails/shared/questions/group",
        locals: { title: reserve, questions: questions } %>
    <% end %>
  </section>
<% end %>
