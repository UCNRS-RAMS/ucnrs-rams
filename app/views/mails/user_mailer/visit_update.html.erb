<div style="max-width: 800px; margin: 0 auto; color: #002045;
  font-size: 14px; font-family: 'Sora', sans-serif"
>
  <%= render partial: "mails/shared/header_user", locals: { presenter: @presenter } %>
  <%= render partial: "mails/shared/hr" %>
  <p style="">
    <span style="color: red;">
      <%= t(".visit_status_has_been_updated_to") %>
    </span>
    <strong><%= t("universal.visit.statuses.#{@presenter.visit.status}") %></strong>
  </p>
  <%= link_to t(".login_and_view_visit"), visit_url(@presenter.id) %>
  <%= render partial: "mails/shared/hr" %>
  <%= simple_format @approval_message %>
  <%= render partial: "mails/shared/hr" %>
  <%= render partial: "mails/shared/visit_detail", locals: { visit: @presenter.visit } %>
  <%= render partial: "mails/shared/project_brief", locals: { project: @presenter.visit_project } %>
</div>
