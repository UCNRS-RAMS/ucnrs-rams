<section data-controller="turbo-content copy-first copy-second">

  <section class="visit-form">
    <%= form.hidden_field :id, value: presenter.id %>
    <div data-purpose="project_type" data-controller="value-projection" data-value-projection-projected-value="<%= form.object.project_type %>">
      <% unless presenter.editing %>
        <div class="project-type-options">
          <%= render partial: presenter.project_type_partial_path, locals: { presenter: presenter, form: form} %>
        </div>
      <% end %>
      <%= render partial: presenter.project_partial_path, locals: { presenter: presenter, form: form} %>
    </div>
    <div>
      <h3><%= t(".titles.purpose") %></h3>
      <div class="text-area">
        <%= form.label :purpose_of_visit, t(".labels.purpose_of_visit") %>
        <%= form.text_area :purpose_of_visit %>
      </div>
    </div>
  </section>

  <div data-controller="followup-content">
    <section class="reserve-info progress-steps">
      <div>
        <h3>
          <%= presenter.reserve_header %>
          <% if presenter.show_browse_reserve_link %>
            <%= link_to t(".links.browse_reserves"), reserves_path, target: "_blank" %>
          <% end %>
        </h3>
      </div>
      <div class="display-row-flex">
        <div class="field">
         <%= render partial: presenter.reserve_partial_path, locals: { presenter: presenter, form: form} %>
        </div>
        <div class="date-range-select">
          <div class="field">
            <%= form.label :start_date, t(".labels.arrival"), class:"reserve-lable" %>
            <div class="date-time-select">
              <%= form.date_field(:start_date, value: presenter.start_date, data: { action: "change->copy-first#copy" }) %>
              <%= form.collection_select(:start_time, presenter.time_options, :value, :human, aria: { label: t(".aria.arrival_time") }) %>
            </div>
          </div>
          <span class="separator"></span>
          <div class="field">
            <%= form.label :end_date, t(".labels.departure") %>
            <div class="date-time-select">
              <%= form.date_field(:end_date, value: presenter.end_date, data: { action: "change->copy-second#copy" }) %>
              <%= form.collection_select(:end_time, presenter.time_options, :value, :human, aria: { label: t(".aria.departure_time") }) %>
            </div>
          </div>
        </div>
      </div>
      <div data-followup-content-target="destination" data-followup-content-url-value="<%= visits_reserve_input_url("VALUE") %>" class="reserve-specific-fields">
        <%= render partial: "visits/reserve_inputs/fields",
          locals: { form_values: presenter.form, presenter: presenter }
        %>
      </div>
    </section>
    <%= render partial: "shared/visits/visitors_table",
      locals: { presenter: presenter } if presenter.user_visits.present?
    %>
    <section class="amenities visit-form" id="amenities-select"
      data-followup-content-target="destination"
      data-followup-content-url-value="<%= visits_amenities_url(reserve_id: "VALUE") %>"
    >
      <header class="amenities-header">
        <h3>
          <%= t(".titles.select_amenities") %>
          <span><%= t(".alt_text.optional")%></span>
        </h3>
        <span><%= t(".alt_text.rate_determined", institution: presenter.user_institution_type) %></span>
      </header>
      <div class="amenity-options">
        <% presenter.amenities_by_group_label.each do |group_label, amenities| %>
          <%= render partial: "visits/amenities/amenities",
            locals: { group_label: group_label, amenities: amenities }
          %>
        <% end %>
      </div>
    </section>
  </div>

  <section class="visit-form footer progress-steps">
    <%= render presenter.save_partial_path %>
  </section>
</section>
