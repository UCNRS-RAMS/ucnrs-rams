<section class="visit-reserve_question">
  <h2 class="main-header"><%= t(".reserve_questions") %></h2>
  <div id="reserve_question-summary-list">
    <% presenter.reserve_answers.each do |reserve_name, reserve_answers| %>
      <div class="answers-list">
        <% reserve_answers.each do |reserve_answer| %>
          <div class="question-answer">
            <p class="question"><%= reserve_answer.reserve_question_question %></p>
            <p class="answer"><strong><%= reserve_answer.answer %></strong></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>  
<section class="visit-visitors">
  <h2 class="main-header"><%= t(".visitors", size: presenter.visitor_count) %></h2>
  <%= render partial: "visits/visitors_summary", locals: { presenter: presenter } %>
</section>
<section class="visit-amenities">
  <h2 class="main-header"><%= t(".amenities", size: presenter.amenity_count) %></h2>
  <%= render partial: "visits/amenities_summary", locals: { presenter: presenter } %>
</section>
