<nav class="navbar" role="navigation">
  <div class="navbar-container container">
    <div class="left-side">
      <%= image_tag "navbar-logo.svg", height: "57px", alt: "rams navbar logo", class: "logo" %>
      <h1 class="title">RAMS</h1>
      <small id="title-extra">Natural Reserve System</small>
    </div>
    <% if current_user.present? %>
      <div class="right-side">
        <ul class="navbar-nav">
          <li> <%= link_to I18n.t(".navbar.link.visits"), "#", class:"nav-link #{active_class_for("visits")} #{active_class_for("home")}" %> </li>
          <li> <%= link_to I18n.t(".navbar.link.reserves"), "#", class:"nav-link #{active_class_for("reserves")}" %> </li>
          <li> <%= link_to I18n.t(".navbar.link.my_projects"), "#", class:"nav-link #{active_class_for("projects")}" %> </li>
          <li> <%= link_to I18n.t(".navbar.link.help"), "#", class:"nav-link #{active_class_for("help")}" %> </li>
          <li> <%= link_to I18n.t(".navbar.link.account"), "#", class:"nav-link #{active_class_for("users")}" %> </li>
          <li> <%= link_to I18n.t(".navbar.link.sign_out"), destroy_user_session_url, class:"nav-link #{active_class_for("sessions")}", data: { turbo: false } %> </li>
          <li> <%= link_to I18n.t(".navbar.link.schedule_visit"), "#", class:"nav-link schedule #{active_class_for("visits")}" %></li>
        </ul>

        <%= image_tag 'hamburger.svg', alt: "hamburger menu", class: "navbar-hamburger display-none" %>
      </div>
    <% end %>
  </div>
</nav>
