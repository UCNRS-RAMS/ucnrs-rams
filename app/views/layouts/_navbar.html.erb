<div class="navbar">
  <div class="container">
    <div class="navbar-content">
      <div class="left-side">
        <%= link_to dashboard_index_path, class: "title-link" do %>
          <%= image_tag "ucnrs-logo.svg", alt: t("alt.ucnrs_logo"), height: "57px", class: "logo" %>
        <% end %>
        <h1 class="title">
          <%= link_to "RAMS", dashboard_index_path, class: "title-link" %>
        </h1>
        <small id="title-extra">
          <%= link_to dashboard_index_path, class: "title-link" do %>
            University of California<br />Natural Reserve System
          <% end %>
        </small>
      </div>
      <div class="right-side">
        <ul class="navbar-nav">
          <% if layout_presenter.current_user_logged_in? %>
            <li>
              <%= link_to t(".link.home"), dashboard_index_path,
                class: ["nav-link", active_class_for("dashboard")] %>
            </li>
            <li>
              <%= link_to t(".link.visits"), home_index_path,
                class: ["nav-link", active_class_for("home")] %>
            </li>
            <li>
              <%= link_to t(".link.projects"), projects_path,
                class: ["nav-link", active_class_for("projects")] %>
            </li>
            <li>
              <%= link_to t(".link.reserves"), reserves_path,
                class: ["nav-link", active_class_for("reserves")] %>
            </li>
            <li>
              <%= link_to "https://ramshelp.ucnrs.org/", id: "help-link", class: ["nav-link", active_class_for("helps")],
                target: "_blank" do %>
                <%= t(".link.help") %>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 22 22" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-external-link">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              <% end %>
            </li>
            <li>
              <%= link_to t(".link.schedule_visit"), new_visit_path,
                class: ["nav-link", "schedule", active_class_for("visits")] %>
            </li>
            <li>
              <%= link_to t(".aria.sign_out"), href: destroy_user_session_path,
                title: t(".aria.sign_out"), "aria-label": t(".aria.sign_out"),
                class: ["nav-link", "nav-link-icon"], id: "log-out" do
              %>
                <span id="log-out-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-log-out">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                  </svg>
                </span>
              <% end %>
            </li>
            <li>
              <%= link_to t(".aria.my_profile"), href: edit_user_registration_path,
                title: t(".aria.my_profile"), "aria-label": t(".aria.my_profile"),
                class: ["nav-link", "nav-link-icon"] do
              %>
                <%= tag.span layout_presenter.current_user.initials, id: "user-initials" %>
              <% end %>
            </li>

          <% else %>
            <li>
              <%= link_to t(".link.reserves"), reserves_path,
                class: ["nav-link", active_class_for("reserves")] %>
            </li>
            <li>
              <%= link_to t(".link.project_search"), "#",
                class: ["nav-link", active_class_for("project_search")] %>
            </li>
            <li>
              <%= link_to t(".link.schedule_visit"), new_visit_path,
                class: ["nav-link", "schedule", active_class_for("visits")] %>
            </li>

          <% end %>
        </ul>

        <%= image_tag 'hamburger.svg', alt: t(".alt_text.mobile_menu"),
          class: "navbar-hamburger display-none"
        %>
      </div>
    </div>
  </div>
</div>
