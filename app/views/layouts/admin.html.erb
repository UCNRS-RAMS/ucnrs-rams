<!DOCTYPE html>
<html lang="en">
  <head>
    <title>UC Nature RAMS | Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= stylesheet_link_tag 'simple_calendar', media: 'all' %>
    <%= javascript_pack_tag 'application' %>
    <%= favicon_link_tag 'favico.png' %>

    <%= render partial: "layouts/fonts" %>
  </head>

  <body class="admin <%= body_class %>">
    <header>
      <%= render partial: 'layouts/domain_banner' %>
      <h1>Admin</h1>
      <%= render "shared/flash" %>
    </header>
    <main role="main">
      <div class="container">
        <%= yield %>
      </div>
    </main>
    <%= render partial: "layouts/modal" %>
  </body>
</html>
