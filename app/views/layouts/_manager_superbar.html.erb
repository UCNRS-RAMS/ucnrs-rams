<div class="manager-navbar upper">
  <div class="container">
    <ul class="navbar-nav">
      <li><%= I18n.t(".navbar.link.welcome_back", name: current_user.full_name) %></li>
      <% if current_reserve.present? %>
        <li class="dropdown" data-controller="dropdown">
          <%= link_to current_reserve.name, "#", class: "dropdown-toggle", data: { action: "click->dropdown#toggle click@window->dropdown#hide"} %>
          <div class="dropdown-menu" data-dropdown-class="show" data-dropdown-target= "dropdown">
            <header><%= I18n.t(".navbar.link.your_managed_reserves") %></header>
            <hr />
            <% current_user.managed_reserves.alphabetized.each do |reserve| %>
              <%= link_to reserve.short_name, manager_reserve_dashboard_path(reserve), class: "dropdown-item" %>
            <% end%>
          </div>
        </li>
      <% end %>
      <li class="dropdown" data-controller="dropdown">
        <%= link_to("#", class: "dropdown-toggle", data: { action: "click->dropdown#toggle click@window->dropdown#hide"}) do %>
          <%= manager_namespace? ? I18n.t(".navbar.link.manager_view") : I18n.t(".navbar.link.public_view") %>
        <% end %>
        <div class="dropdown-menu" data-dropdown-class="show" data-dropdown-target= "dropdown">
          <%= if manager_namespace?
            link_to I18n.t(".navbar.link.go_to_public_view"), root_path, class: "dropdown-item"
          else
            link_to I18n.t(".navbar.link.go_to_manager_view"), manager_reserve_dashboard_path(current_user.managed_reserve_ids.first), class: "dropdown-item"
          end %>
        </div>
      </li>
      <li><%= link_to image_tag("icon-user-navbar.svg", alt: I18n.t(".navbar.alt_text.icon_user")), manager_namespace? ? edit_manager_reserve_user_path(current_reserve, current_user) : edit_user_registration_path, class: "icon-only" %></li>
      <li><%= link_to image_tag("icon-sign-out-navbar.svg", alt: I18n.t(".navbar.alt_text.icon_sign_out")), destroy_user_session_path, class: "icon-only" %> </li>
    </ul>
  </div>
</div>
