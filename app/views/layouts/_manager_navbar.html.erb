<div class="manager-navbar lower">
  <div class="container">
    <div class="left-side">
      <%= image_tag "navbar-logo.svg", alt: t("alt.ucnrs_logo"), height: "57px", class: "logo" %>
      <h1 class="title">RAMS</h1>
      <small id="title-extra">University of California<br />Natural Reserve System</small>
    </div>
    <div class="right-side">
      <ul class="navbar-nav">
        <li> <%= link_to I18n.t(".navbar.link.visits"),
                manager_reserve_dashboard_path(current_reserve),
                class:"nav-link #{active_class_for("dashboard")}" %>
        </li>
        <li> <%= link_to I18n.t(".navbar.link.projects"),
                manager_reserve_projects_path(current_reserve),
                class:"nav-link #{active_class_for("projects")}" %>
        </li>
        <li> <%= link_to I18n.t(".navbar.link.invoices"), "#", class:"nav-link" %> </li>
        <li> 
          <%= link_to I18n.t(".navbar.link.reports"), 
                report_part_1_manager_reserve_report_path(current_reserve.id, Date.current.year), 
                class:"nav-link #{active_class_for("reports")}" %> 
        </li>
        <li> 
          <%= link_to I18n.t(".navbar.link.reserve_info"),
                edit_manager_reserve_reserve_info_reserve_details_path(current_reserve),
                class:"nav-link #{active_class_for("reserve_details")}" %>
        </li>
        <li> <%= link_to I18n.t(".navbar.link.users"), "#", class:"nav-link" %> </li>
        <li> <%= link_to I18n.t(".navbar.link.help"), "#", class:"nav-link" %> </li>
      </ul>

      <%= image_tag "hamburger.svg", alt: I18n.t(".navbar.alt_text.mobile_menu"), class: "navbar-hamburger display-none" %>
    </div>
  </div>
</div>
