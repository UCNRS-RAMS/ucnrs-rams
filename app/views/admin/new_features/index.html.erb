<section class="content">
  <header>
    What's New/Changed
  </header>
  <div>
    <% @presenter.new_features.each do |new_feature| %>
      <section>
        <%= new_feature.title %> | <%= link_to t("edit"), edit_admin_new_feature_path(new_feature) %>
      </section>
    <% end %>

    <%= link_to t("new"), new_admin_new_feature_path %>
  </div>
</section>
